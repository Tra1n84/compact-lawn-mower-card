{
  "name": "compact-lawn-mower-card",
  "version": "1.3.0",
  "description": "A compact, modern and feature-rich custom card for your robotic lawn mower in Home Assistant",
  "scripts": {
    "build": "rollup -c",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\" \"*.json\""
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/estree": "^1.0.8",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "dependencies": {
    "custom-card-helpers": "^2.0.0",
    "lit": "^3.3.2"
  }
}
